# EditorConfig: https://editorconfig.org
# Top-most EditorConfig file — drop this at the root of your .NET C# project.
root = true

##########################################
# Global file formatting
##########################################
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

##########################################
# C# files
##########################################
[*.cs]

#### Core formatting ####
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

#### .NET / C# language conventions ####

# System usings first
dotnet_sort_system_directives_first = true
csharp_style_namespace_declarations = file_scoped:warning

# === Exception #2: NEVER use `var` — always use explicit types ===
csharp_style_var_for_built_in_types    = false:error
csharp_style_var_when_type_is_apparent = false:error
csharp_style_var_elsewhere             = false:error

# Prefer braces
csharp_prefer_braces = true:warning

##########################################
# Naming conventions
##########################################

#### Standard .NET style for everything else ####

# PascalCase for public/protected members
dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_symbols.public_symbols.applicable_kinds           = property, method, event, class, struct, interface, delegate, namespace
dotnet_naming_symbols.public_symbols.applicable_accessibilities = public, protected, internal, protected_internal

dotnet_naming_rule.public_pascal_case.style    = pascal_case
dotnet_naming_rule.public_pascal_case.symbols  = public_symbols
dotnet_naming_rule.public_pascal_case.severity = warning

#### === Exception #1: Constants / enums / static readonly → Java style (UPPER_SNAKE_CASE) === ####

# Style definition: UPPER_SNAKE_CASE
dotnet_naming_style.java_upper_snake.capitalization = all_upper
dotnet_naming_style.java_upper_snake.word_separator = _

# (A) const fields
dotnet_naming_symbols.const_fields.applicable_kinds           = field
dotnet_naming_symbols.const_fields.applicable_accessibilities = *


dotnet_naming_rule.const_fields_java_style.style     = java_upper_snake
dotnet_naming_rule.const_fields_java_style.symbols   = const_fields
dotnet_naming_rule.const_fields_java_style.severity  = error


# (C) static readonly fields
dotnet_naming_symbols.static_readonly_fields.applicable_kinds           = field
dotnet_naming_symbols.static_readonly_fields.applicable_accessibilities = *


dotnet_naming_rule.static_readonly_java_style.style     = java_upper_snake
dotnet_naming_rule.static_readonly_java_style.symbols   = static_readonly_fields
dotnet_naming_rule.static_readonly_java_style.severity  = error


