// askmefirst — example config.
//
// Copy to your OS-standard location:
//   Windows:  %APPDATA%\AskMeFirst\config.json
//   macOS:    ~/Library/Application Support/AskMeFirst/config.json
//   Linux:    ~/.config/AskMeFirst/config.json
//
// Run `askmefirst init` to do this for you. The parser ignores `//` and `/* */`.
// Each section is optional; an empty config uses sensible defaults.

{
  // Settings applied to every URL unless a rule overrides them.
  "settings": {
    "stripTracking": true,            // strip utm_/fbclid/etc from query strings
    "unshorten": false,               // show resolved URL for known shorteners (picker only)
    "inventoryCacheTtl": "1.00:00:00", // (unused for now — discovery cache invalidation is manual via `askmefirst refresh`)
    "unshortenTimeout": "00:00:01"    // picker unshortener timeout
  },

  // Extra tracking parameters beyond the built-in ~20.
  // Set trackingParamsOverride=true to REPLACE the built-in list.
  "trackingParamsExtra": ["si", "feature", "igshid"],
  "trackingParamsOverride": false,

  // Extra shortener domains beyond the built-in ~27.
  // Set unshortenDomainsOverride=true to REPLACE the built-in list.
  "unshortenDomainsExtra": [],
  "unshortenDomainsOverride": false,

  // Browser profiles. One browser can have many profiles; rules pick by profileId.
  // "directory" is the OS-specific folder name (Chrome) / "name" is the profile name (Firefox).
  "profiles": [
    {
      "id": "chrome-work-profile",
      "browserId": "chrome",
      "directory": "Default",
      "displayName": "Work"
    }
  ],

  // Browsers referenced from rules by id.
  //   "executable": "auto" — resolved via OS discovery
  //   "executable": "/abs/path" — pinned to a specific install
  "browsers": [
    {
      "id": "chrome",
      "displayName": "Chrome",
      "executable": "auto",
      "profileId": "chrome-work-profile"
    }
  ],

  // Routing rules. First match wins (sorted by priority, ties by array order).
  // See docs/rule-engine.md for the full predicate and action vocabulary.
  "rules": [
    {
      "name": "GitHub pull requests to Chrome (Work)",
      "priority": 100,
      "when": {
        "urlRegex": "^https://github\\.com/[^/]+/[^/]+/pull/\\d+"
      },
      "then": {
        "browser": "chrome",
        "profileId": "chrome-work-profile"
      }
    },
    {
      "name": "Anything else: show the picker (catchall)",
      "priority": 0,
      "when": {},
      "then": {
        "browser": "chrome"
      }
    }
  ]
}
